<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_09riimu" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_1c1l9t7">
    <bpmn:participant id="Participant_1int0s4" name="Процесс выдачи ИТ-оборудования" processRef="Process_1cp6i41" />
    <bpmn:participant id="Participant_0yyj5ad" name="Поставщик" />
    <bpmn:messageFlow id="Flow_1noog94" sourceRef="Activity_12237f3" targetRef="Participant_0yyj5ad" />
    <bpmn:messageFlow id="Flow_0ae7q1y" sourceRef="Participant_0yyj5ad" targetRef="Event_04573sm" />
    <bpmn:textAnnotation id="TextAnnotation_0dr81ci">
      <bpmn:text>Не понятно кто физически заносит заявку в Систему 1? В тексте пропущен шаг вноса данных в систему 1. Техподдержка вносит руками, или заявка через почту автоматом падает в систему 1?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0g3qp40">
      <bpmn:text>Как номер передаётся пользователю?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0hshjqw">
      <bpmn:text>Тех.поддержка работает в 2х системах? Нет ли интеграции между системой 1 и системой 2?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0qzx6r1">
      <bpmn:text>Что значит принять? Меняется ли статус в системе 2?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ng4j7c">
      <bpmn:text>Заявка делается через почту. В системе 2 и 3 меняется статус на ожидание поставки от поставщика?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0a7zk1c">
      <bpmn:text>Оборудование передаётся, но нигде не сказано как оно списывается в Системе 3. Также неясно, как именно вызывается логистика</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_166oyxy">
      <bpmn:text>Как пользователь узнает, что его оборудование приехало и его можно забрать? Нужно промежуточное действие по оповещению.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_16zfa1t">
      <bpmn:text>У тех. поддержки есть права на закрытие в системе 2? Снабжение должны сами закрывать свою часть работы после выдачи оборудования.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ysr49n">
      <bpmn:text>Как именно технически пользователь может выставить оценку? По почте, по телефону, через ЛК?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_17weocl" associationDirection="None" sourceRef="Activity_0kopzzj" targetRef="TextAnnotation_0dr81ci" />
    <bpmn:association id="Association_1xoxz4d" associationDirection="None" sourceRef="Activity_0wexakn" targetRef="TextAnnotation_0g3qp40" />
    <bpmn:association id="Association_1jkniae" associationDirection="None" sourceRef="Activity_0mky7co" targetRef="TextAnnotation_0qzx6r1" />
    <bpmn:association id="Association_1y37s54" associationDirection="None" sourceRef="Activity_1ecdiid" targetRef="TextAnnotation_0a7zk1c" />
    <bpmn:association id="Association_1iwhyfl" associationDirection="None" sourceRef="Activity_1de4w3k" targetRef="TextAnnotation_166oyxy" />
    <bpmn:association id="Association_1eujli5" associationDirection="None" sourceRef="Activity_0qoqtfl" targetRef="TextAnnotation_16zfa1t" />
    <bpmn:association id="Association_165kkvx" associationDirection="None" sourceRef="Activity_1dwsak2" targetRef="TextAnnotation_0ysr49n" />
  </bpmn:collaboration>
